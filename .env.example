# Database connection string
# See: https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Auth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# Public URL of the app (required in production for auth redirects)
AUTH_URL="http://localhost:3000"

# Optional OIDC SSO (e.g. Pocket ID) - leave unset to disable.
# Register a client with redirect URI: {AUTH_URL}/api/auth/callback/pocketid
#OIDC_ISSUER="https://id.example.com"
#OIDC_CLIENT_ID="your-client-id"
#OIDC_CLIENT_SECRET="your-client-secret"
#OIDC_PROVIDER_NAME="PocketID"
